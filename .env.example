# Server Configuration
HOST=0.0.0.0
PORT=4003

# Database Configuration (single URL)
DATABASE_URL=postgres://iam:password123@localhost:5433/iam?sslmode=disable
DB_PREFER_SIMPLE_PROTOCOL=false

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ISSUER=iam-authorization-service
JWT_AUDIENCE=platform-console

# Tenant Configuration
DEFAULT_TENANT_ID=default

# Environment
ENV=development

# Optional
CONFIG_PATH=src/config/config.yaml
SEED_ON_STARTUP=false
ALLOW_SEED_ENDPOINT=false
CORS_ALLOWED_ORIGINS=http://localhost:3005,https://wahb-console.salehspace.dev
# Force schema auto-migrate on boot outside development (dev always migrates).
# IAM_AUTO_MIGRATE=true

# Default admin user (seeded by `make seed` / seed-on-startup when present)
ADMIN_EMAIL=admin@example.com
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Email — verification + password reset (SMTP). Unset = email features no-op.
REQUIRE_EMAIL_VERIFICATION=false
SMTP_HOST=
SMTP_PORT=587
SMTP_PASSWORD=
EMAIL_FROM=no-reply@wahb.local
EMAIL_VERIFICATION_BASE_URL=http://localhost:3000/verify-email
EMAIL_RESET_BASE_URL=http://localhost:3000/reset-password

# Object storage for avatar uploads (S3-compatible, same STORAGE_* contract as
# Aggregation). Local dev = MinIO + the shared wahb-media bucket. Empty endpoint
# disables avatar upload.
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=wahb-media
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_PUBLIC_URL=http://localhost:9000
STORAGE_REGION=us-east-1

# CMS enforcement mirror for IAM-owned account suspensions. This token must
# match CMS_IAM_SERVICE_TOKEN configured on Content-Management-System.
CMS_BASE_URL=http://localhost:8080
CMS_IAM_SERVICE_TOKEN=
